{
  "name": "benchy",
  "version": "0.1.0",
  "description": "Self-hosted AI model benchmarking tool",
  "type": "module",
  "bin": {
    "benchy": "./dist/cli.js"
  },
  "scripts": {
    "dev": "concurrently -n server,vite -c cyan,magenta \"tsx watch src/cli.ts start --no-open\" \"vite --config frontend/vite.config.ts\"",
    "build": "tsc -p tsconfig.json && vite build --config frontend/vite.config.ts",
    "start": "node dist/cli.js start",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "fastify": "^5.0.0",
    "open": "^10.1.0",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
